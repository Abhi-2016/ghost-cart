# Gateway service configuration
NODE_ENV=development
PORT=3000

# URL of the Python brain service
# Local dev: http://localhost:8000
# Production: https://your-brain.railway.app (use Railway's internal URL if same project)
BRAIN_BASE_URL=http://localhost:8000

# Shared secret for gateway→brain internal auth
# Must match brain's BRAIN_INTERNAL_SECRET exactly
# Generate with: openssl rand -hex 32
BRAIN_INTERNAL_SECRET=change_me_before_deploy

# Google Places API key — used to auto-locate supported stores near the user
# Get one at: https://console.cloud.google.com/ → APIs & Services → Credentials
# Enable: Places API (New) or Places API
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Log level: debug | info | warn | error (default info)
LOG_LEVEL=info

# ── Observability (optional) ────────────────────────────────────────────────
# Railway captures stdout automatically. To forward JSON logs to Logtail:
#   1. Sign up at https://logtail.com → create a Source (Node.js)
#   2. Copy the source token below
#   3. In Railway: Settings → Log Drains → add Logtail HTTP drain
#      OR set LOGTAIL_SOURCE_TOKEN here if using the Logtail SDK
# Both approaches work; the log drain is zero-code (recommended).
LOGTAIL_SOURCE_TOKEN=
