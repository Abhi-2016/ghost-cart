# Gateway service configuration
NODE_ENV=development
PORT=3000

# URL of the Python brain service
BRAIN_BASE_URL=http://localhost:8000

# Shared secret for gateway→brain internal auth (generate with: openssl rand -hex 32)
BRAIN_INTERNAL_SECRET=change_me_before_deploy

# Google Places API key — used to auto-locate supported stores near the user
# Get one at: https://console.cloud.google.com/ → APIs & Services → Credentials
# Enable: Places API
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
