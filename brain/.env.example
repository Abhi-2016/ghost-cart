# Brain service configuration
ENV=development

# Anthropic API key — never exposed to clients or forwarded to the gateway
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Claude model to use
CLAUDE_MODEL=claude-sonnet-4-6

# Must match gateway's BRAIN_INTERNAL_SECRET
# Generate with: openssl rand -hex 32
# Leave empty to skip auth in local dev only
BRAIN_INTERNAL_SECRET=change_me_before_deploy

# Comma-separated list of origins allowed to call this service (i.e. your gateway URL)
# Local dev: http://localhost:3000
# Production: https://your-gateway.railway.app
ALLOWED_ORIGINS=http://localhost:3000

# In-process response cache
CACHE_MAXSIZE=512
CACHE_TTL=600

# Log level: DEBUG | INFO | WARNING | ERROR (default INFO)
LOG_LEVEL=INFO

# ── Observability (optional) ────────────────────────────────────────────────
# Railway captures stdout automatically. To forward JSON logs to Logtail:
#   1. Sign up at https://logtail.com → create a Source (Python)
#   2. Copy the source token below
#   3. In Railway: Settings → Log Drains → add Logtail HTTP drain
#      OR set LOGTAIL_SOURCE_TOKEN here if using the Logtail SDK
# Both approaches work; the log drain is zero-code (recommended).
LOGTAIL_SOURCE_TOKEN=
