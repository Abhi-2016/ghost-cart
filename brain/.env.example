# Brain service configuration
ENV=development

# Anthropic API key — never exposed to clients
ANTHROPIC_API_KEY=sk-ant-...

# Claude model
CLAUDE_MODEL=claude-sonnet-4-6

# Must match gateway's BRAIN_INTERNAL_SECRET (leave empty to skip auth in local dev)
BRAIN_INTERNAL_SECRET=change_me_before_deploy

# In-process response cache
CACHE_MAXSIZE=512
CACHE_TTL=600
