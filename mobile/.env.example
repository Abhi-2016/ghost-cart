# Mobile app configuration
# Copy to .env and fill in values — .env is gitignored, .env.example is committed

# URL of the deployed gateway service
# Local dev (simulator):        http://localhost:3000
# Local dev (real device):      http://192.168.x.x:3000   ← your machine's local IP
# EAS preview build:            https://your-gateway.railway.app
# EAS production build:         https://your-gateway.railway.app
#
# IMPORTANT for EAS builds: this value is baked into the binary at build time.
# You must set EXPO_PUBLIC_GATEWAY_URL in your EAS project environment variables
# (eas.json env section OR Expo dashboard → Project → Environment Variables)
# before running `eas build`.
EXPO_PUBLIC_GATEWAY_URL=http://localhost:3000
